{
  "name": "tg-mcp",
  "version": "1.3.0",
  "description": "Local MCP server for your Telegram personal account — channels, digests, messaging, folders and more.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "mcp",
    "mcp-server",
    "telegram",
    "mtproto",
    "cursor",
    "claude",
    "model-context-protocol"
  ],
  "bin": {
    "tg-mcp": "dist/index.js",
    "tg-mcp-auth": "dist/auth.js",
    "tg-mcp-logout": "dist/logout.js"
  },
  "files": [
    "dist",
    ".env.example",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc",
    "prepublishOnly": "npm run clean && npm run build",
    "mcp": "node dist/index.js",
    "auth": "node dist/auth.js",
    "logout": "node dist/logout.js",
    "inspect": "npm run build && npx -y @modelcontextprotocol/inspector npm run mcp"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mtcute/node": "^0.30.1",
    "dotenv": "^16.5.0",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3"
  }
}
