{
  "name": "tg-mcp-tools",
  "version": "1.0.0",
  "description": "Local MCP server for your Telegram personal account — channels, digests, messaging, folders and more.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "mcp",
    "mcp-server",
    "telegram",
    "mtproto",
    "mtcute",
    "cursor",
    "claude",
    "model-context-protocol"
  ],
  "bin": {
    "tg-mcp-tools": "dist/index.js",
    "tg-mcp-tools-auth": "dist/auth.js"
  },
  "files": [
    "dist",
    ".env.example",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "mcp": "node dist/index.js",
    "auth": "node dist/auth.js",
    "preauth": "npm run build",
    "premcp": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@mtcute/node": "^0.30.1",
    "dotenv": "^16.5.0",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3"
  }
}
